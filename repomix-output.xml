<file path="src/components/Gallery/DiaryBook.jsx">
import { useState, useEffect } from "react";
import { motion, useMotionValue, useTransform, animate } from "framer-motion";
import galleryData from "../../data/galleryData";
import "./DiaryBook.css";

export default function DiaryBook() {
  const [current, setCurrent] = useState(0);
  const rotateY = useMotionValue(0);
  const shadowOpacityLeft = useTransform(rotateY, [0, -180], [0, 0.5]);
  const shadowOpacityRight = useTransform(rotateY, [0, 180], [0, 0.5]);

  // preload all photos + chibi art into browser cache on mount
  useEffect(() => {
    galleryData.forEach((item) => {
      const img = new Image();
      img.src = item.src;
      const chibiImg = new Image();
      chibiImg.src = item.chibi;
    });
  }, []);

  const photo = galleryData[current];
  const nextPhoto = galleryData[current + 1];
  const prevPhoto = galleryData[current - 1];
  const isLast = current >= galleryData.length - 1;
  const isFirst = current === 0;

  const turnSpring = { type: "spring", stiffness: 45, damping: 18 };

  function goNext() {
    if (isLast) return;
    animate(rotateY, -180, {
      ...turnSpring,
      onComplete: () => {
        setCurrent((c) => c + 1);
        rotateY.set(0);
      },
    });
  }

  function goPrev() {
    if (isFirst) return;
    animate(rotateY, 180, {
      ...turnSpring,
      onComplete: () => {
        setCurrent((c) => c - 1);
        rotateY.set(0);
      },
    });
  }

  return (
    <section className="diary-section">
      <div className="book-spread">
        <div className="page page-caption">
          <span className="page-number">
            {String(current + 1).padStart(3, "0")}
          </span>

          <motion.div
            key={photo.id}
            className="chibi-frame"
            initial={{ opacity: 0, y: 15, rotate: -6, scale: 0.9 }}
            animate={{ opacity: 1, y: 0, rotate: -3, scale: 1 }}
            transition={{ duration: 0.5, ease: [0.16, 1, 0.3, 1] }}
          >
            <img src={photo.chibi} alt="" className="chibi-art" />
          </motion.div>

          <p className="caption-text">
            {photo.caption || "her caption goes here."}
          </p>
        </div>

        <div className="page-flip-wrap">
          {nextPhoto && (
            <div className="page page-photo page-under">
              <img src={nextPhoto.src} alt="" />
            </div>
          )}
          {prevPhoto && (
            <div className="page page-photo page-under">
              <img src={prevPhoto.src} alt="" />
            </div>
          )}

          <motion.div
            className="page page-photo page-active"
            style={{ rotateY, transformOrigin: "left center" }}
          >
            <img src={photo.src} alt={photo.caption || "photo"} />
            <motion.div
              className="page-shadow page-shadow-left"
              style={{ opacity: shadowOpacityLeft }}
            />
            <motion.div
              className="page-shadow page-shadow-right"
              style={{ opacity: shadowOpacityRight }}
            />
          </motion.div>
        </div>
      </div>

      <div className="page-controls">
        <button className="page-nav-btn" onClick={goPrev} disabled={isFirst}>
          ← prev
        </button>
        <span className="page-hint">
          {String(current + 1).padStart(3, "0")} / {String(galleryData.length).padStart(3, "0")}
        </span>
        <button className="page-nav-btn" onClick={goNext} disabled={isLast}>
          next →
        </button>
      </div>
    </section>
  );
}
</file>

